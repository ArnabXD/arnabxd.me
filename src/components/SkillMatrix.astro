---
import { data } from "~/data";

const groups = data.skills;
const formatTitle = (t: string) =>
	t
		.toLowerCase()
		.replace(/_/g, " ")
		.replace(/\b\w/g, (c) => c.toUpperCase());
---

<div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
	{
		groups.map((group, gi) => (
			<div class="grid grid-cols-12 gap-3 py-7 md:py-8 border-b border-rule-soft items-baseline">
				<span class="col-span-2 font-mono text-[11px] tabular text-ink-4 self-start mt-1 tracking-widest">
					{String(gi + 1).padStart(2, "0")}
				</span>
				<div class="col-span-10">
					<h3 class="font-display text-[22px] md:text-[26px] text-ink leading-tight font-semibold tracking-[-0.03em]">
						{formatTitle(group.title)}
						<span class="ml-2 font-mono text-[11px] text-ink-4 tabular align-middle font-normal tracking-normal">
							[{String(group.skills.length).padStart(2, "0")}]
						</span>
					</h3>
					<ul class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-[14.5px] text-ink-2">
						{group.skills.map((skill, si) => (
							<li class="inline-flex items-center gap-2">
								{si > 0 && (
									<span aria-hidden="true" class="text-mark">
										·
									</span>
								)}
								<span class="hover:text-mark transition-colors cursor-default">
									{skill}
								</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		))
	}
</div>
