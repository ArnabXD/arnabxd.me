---
import { data } from "~/data";

const groups = data.skills;
const formatTitle = (t: string) =>
	t
		.toLowerCase()
		.replace(/_/g, " ")
		.replace(/\b\w/g, (c) => c.toUpperCase());
---

<div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
	{
		groups.map((group, gi) => (
			<div class="group grid grid-cols-12 gap-3 py-7 md:py-8 border-b border-rule-soft items-baseline transition-colors hover:bg-paper-2/10 px-2 -mx-2 rounded">
				<span class="col-span-12 md:col-span-2 font-mono text-[11px] tabular text-mark self-start mt-1.5 tracking-widest">
					[skill_0{gi + 1}]
				</span>
				<div class="col-span-12 md:col-span-10">
					<h3 class="font-display text-[22px] md:text-[24px] text-ink leading-tight font-semibold tracking-[-0.03em] group-hover:text-mark transition-colors">
						{formatTitle(group.title)}
						<span class="ml-2 font-mono text-[11px] text-ink-4 tabular align-middle font-normal tracking-normal">
							[{String(group.skills.length).padStart(2, "0")}]
						</span>
					</h3>
					<ul class="mt-4 flex flex-wrap items-center gap-2">
						{group.skills.map((skill) => (
							<li class="px-2.5 py-1 border border-rule-soft bg-paper-2/65 hover:bg-paper-3/45 hover:border-mark hover:text-mark rounded font-mono text-[12px] text-ink-2 transition-colors cursor-default">
								{skill}
							</li>
						))}
					</ul>
				</div>
			</div>
		))
	}
</div>
