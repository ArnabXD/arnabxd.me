---
import { data } from "~/data";

const { site, nav } = data;
const path = Astro.url.pathname;
---

<div data-nav-shell class="sticky top-0 z-40">
	<header
		class="relative mx-auto max-w-300 px-6 md:px-12 lg:px-16 flex items-center justify-between gap-3 py-6 md:py-7 fade"
	>
		<a
			href="/"
			class="group inline-flex items-center gap-0.5 font-mono text-[16px] md:text-[18px] leading-none tracking-tight text-ink transition-colors shrink-0"
			aria-label={site.name}
		>
			<span class="text-mark group-hover:text-ink transition-colors">&lt;</span>
			<span
				class="font-display font-semibold tracking-[-0.02em] text-[18px] md:text-[20px] group-hover:text-mark transition-colors"
				>Arnab</span
			>
			<span class="text-mark group-hover:text-ink transition-colors">/&gt;</span
			>
		</a>

		<nav aria-label="Primary" class="flex items-center gap-1 sm:gap-2">
			{
				nav.map((item) => {
					const active = path.startsWith(item.href);
					return (
						<a
							href={item.href}
							class:list={[
								"group relative inline-flex items-baseline gap-2 px-2.5 sm:px-3 py-1.5 text-[14px] sm:text-[15px] transition-colors",
								active ? "text-ink" : "text-ink-3 hover:text-ink",
							]}
						>
							<span class="hidden sm:inline font-mono text-[11px] text-ink-4 tabular">
								{item.short}
							</span>
							<span>{item.label}</span>
							{active && (
								<span
									aria-hidden="true"
									class="absolute left-2.5 right-2.5 sm:left-3 sm:right-3 -bottom-0.5 h-px bg-mark"
								/>
							)}
						</a>
					);
				})
			}
		</nav>
	</header>
</div>

<script is:inline>
	(function () {
		var shell = document.querySelector("[data-nav-shell]");
		if (!shell) return;
		var update = function () {
			if (window.scrollY > 0) {
				shell.style.background = "rgba(243, 237, 226, 0.92)";
				shell.style.borderBottom = "1px solid #cdc5b3";
			} else {
				shell.style.background = "";
				shell.style.borderBottom = "";
			}
		};
		update();
		window.addEventListener("scroll", update, { passive: true });
	})();
</script>
