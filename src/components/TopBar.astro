---
import { data } from "~/data";

const { site } = data;

const nav = [
  { label: "Works", href: "/works", short: "01" },
  { label: "Writing", href: "/blog", short: "02" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const target = href.replace(/\/$/, "") || "/";
  if (target === "/") return current === "/";
  if (target.startsWith("/#")) return false;
  return current.startsWith(target);
};
---

<!-- sentinel: when out of view, nav becomes "stuck" -->
<div data-nav-sentinel aria-hidden="true" class="h-px w-full"></div>

<div
  data-nav-shell
  class="sticky top-0 z-40"
>
  <!-- gradual blur: 5 stacked blur layers (1/2/4/8/14px) + tint. The wrapper
       extends well past the header (pb-16) so each layer's mask has room to
       taper out smoothly rather than ending on a hard edge. -->
  <div data-nav-blur class="nav-blur-stack pb-16" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>

  <header
    class="relative mx-auto max-w-[1200px] px-6 md:px-12 lg:px-16 flex items-center justify-between gap-3 py-6 md:py-7 fade"
  >
    <a
      href="/"
      class="group inline-flex items-center gap-[2px] font-mono text-[15px] md:text-[16px] leading-none tracking-tight text-ink transition-colors shrink-0"
      aria-label={site.name}
    >
      <span class="text-mark group-hover:text-ink transition-colors">&lt;</span>
      <span class="font-display font-semibold tracking-[-0.02em] text-[16px] md:text-[18px] group-hover:text-mark transition-colors">Arnab</span>
      <span class="text-mark group-hover:text-ink transition-colors">/&gt;</span>
    </a>

    <nav aria-label="Primary" class="flex items-center gap-1 sm:gap-2">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "group relative inline-flex items-baseline gap-2 px-2.5 sm:px-3 py-1.5 text-[12.5px] sm:text-[13px] transition-colors",
              isActive(item.href)
                ? "text-ink"
                : "text-ink-3 hover:text-ink",
            ]}
          >
            <span class="hidden sm:inline font-mono text-[10px] text-ink-4 tabular">
              {item.short}
            </span>
            <span>{item.label}</span>
            {isActive(item.href) && (
              <span
                aria-hidden="true"
                class="absolute left-2.5 right-2.5 sm:left-3 sm:right-3 -bottom-0.5 h-px bg-mark"
              />
            )}
          </a>
        ))
      }
    </nav>
  </header>
</div>

<script is:inline>
  (function () {
    var sentinel = document.querySelector("[data-nav-sentinel]");
    var blur = document.querySelector("[data-nav-blur]");
    if (!sentinel || !blur) return;

    var io = new IntersectionObserver(
      function (entries) {
        blur.setAttribute("data-stuck", String(!entries[0].isIntersecting));
      },
      { threshold: 0, rootMargin: "0px" }
    );
    io.observe(sentinel);
  })();
</script>
