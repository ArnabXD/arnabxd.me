---
import { data } from "~/data";

const items = data.education;
---

<div class="mt-12 md:mt-16">
	{
		items.map((edu) => (
			<article class="grid grid-cols-12 gap-4 md:gap-6 py-8 md:py-10 border-b border-rule-soft last:border-b-0">
				<div class="col-span-12 md:col-span-1">
					<span class="font-mono text-[11px] tabular text-ink-4 tracking-widest">
						01
					</span>
				</div>

				<div class="col-span-12 md:col-span-7">
					<p class="eyebrow mb-1.5">Institution</p>
					<h3 class="font-display text-[26px] md:text-[34px] leading-[1.05] tracking-[-0.03em] text-ink font-medium">
						{edu.institution}
					</h3>
					<p class="mt-3 text-[14px] text-ink-2">
						<span class="font-mono italic text-[14px]">{edu.degree}</span>
					</p>
				</div>

				<div class="col-span-6 md:col-span-2 md:text-right">
					<p class="eyebrow mb-1.5">Period</p>
					<p class="font-mono text-[14px] tabular text-ink">{edu.period}</p>
				</div>

				<div class="col-span-6 md:col-span-2 md:text-right">
					<p class="eyebrow mb-1.5">CGPA</p>
					<p class="font-display text-[28px] text-mark leading-none font-semibold tabular tracking-[-0.04em]">
						{edu.cgpa}
					</p>
				</div>
			</article>
		))
	}
</div>
