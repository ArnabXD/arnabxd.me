---
import type { CollectionEntry } from "astro:content";

type Props = {
	entries: CollectionEntry<"blog">[];
	compact?: boolean;
};

const { entries, compact = false } = Astro.props;

const fmt = (date: Date) =>
	date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "2-digit",
	});
---

<ul class="mt-12 md:mt-16">
	{
		entries.map((post, i) => (
			<li>
				<a
					href={`/blog/${post.id}`}
					class="group grid grid-cols-12 gap-4 md:gap-6 py-7 md:py-9 border-b border-rule-soft items-baseline transition-colors hover:bg-paper-2/40 -mx-3 md:-mx-6 px-3 md:px-6"
				>
					<span class="col-span-2 md:col-span-1 font-mono text-[11px] tabular text-ink-4 tracking-[0.1em] self-start mt-2">
						{String(i + 1).padStart(2, "0")}
					</span>

					<div class="col-span-10 md:col-span-8">
						<h3 class="font-display text-[26px] md:text-[34px] leading-[1.05] tracking-[-0.035em] text-ink font-semibold group-hover:text-mark transition-colors">
							{post.data.title}
						</h3>
						{!compact && (
							<p class="mt-3 text-[15px] text-ink-2 leading-relaxed max-w-[58ch] line-clamp-2">
								{post.data.description}
							</p>
						)}
						{post.data.tags.length > 0 && (
							<ul class="mt-3 flex flex-wrap gap-x-3 text-[11px] font-mono tabular text-ink-3 tracking-[0.05em]">
								{post.data.tags.slice(0, 4).map((t, ti) => (
									<li class="inline-flex items-center gap-3">
										{ti > 0 && (
											<span aria-hidden="true" class="text-ink-5">
												/
											</span>
										)}
										{t}
									</li>
								))}
							</ul>
						)}
					</div>

					<div class="col-span-12 md:col-span-3 md:text-right">
						<time
							datetime={post.data.pubDate.toISOString()}
							class="font-mono text-[12px] tabular text-ink-3 tracking-[0.04em]"
						>
							{fmt(post.data.pubDate)}
						</time>
						<p class="mt-2 font-mono text-[10px] tabular text-ink-4 tracking-[0.16em] uppercase inline-flex items-center gap-1.5 group-hover:text-mark transition-colors md:justify-end md:flex">
							Read{" "}
							<span
								aria-hidden="true"
								class="transition-transform group-hover:translate-x-0.5"
							>
								→
							</span>
						</p>
					</div>
				</a>
			</li>
		))
	}
</ul>
