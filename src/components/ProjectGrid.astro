---
import { data } from "~/data";

type Props = {
	limit?: number;
};

const { limit } = Astro.props;
const projects = limit ? data.projects.slice(0, limit) : data.projects;
---

<div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0">
	{
		projects.map((p, i) => {
			const isClient = p.confidential === true;
			const Tag = isClient ? "div" : "a";
			const tagProps = isClient
				? {}
				: { href: p.link, target: "_blank", rel: "noreferrer" };

			return (
				<Tag
					{...tagProps}
					class={`group relative grid grid-cols-12 gap-3 py-7 md:py-8 border-b border-rule-soft items-baseline transition-colors -mx-2 px-2 ${!isClient ? "hover:bg-paper-2/40" : ""}`}
				>
					<span class="col-span-2 font-mono text-[11px] tabular text-ink-4 self-start mt-2 tracking-widest">
						{String(i + 1).padStart(2, "0")}
					</span>

					<div class="col-span-10">
						<div class="flex items-baseline justify-between gap-3">
							<h3
								class={`font-display text-[24px] md:text-[28px] leading-[1.05] tracking-[-0.03em] text-ink font-semibold transition-colors ${!isClient ? "group-hover:text-mark" : ""}`}
							>
								{p.title}
							</h3>
							<span class="shrink-0 font-mono text-[11px] tabular text-ink-4 tracking-[0.04em]">
								{p.period}
							</span>
						</div>

						{(p.client || p.role) && (
							<p class="mt-2 font-mono text-[10px] tabular tracking-[0.12em] uppercase text-ink-4 leading-relaxed">
								<span class="text-mark">◆</span>
								{[p.client?.industry, p.client?.region, p.role]
									.filter(Boolean)
									.join(" · ")}
							</p>
						)}

						<p class="mt-3 text-[14.5px] text-ink-2 leading-relaxed line-clamp-4 max-w-[58ch]">
							{p.description}
						</p>

						{p.outcome && (
							<p class="mt-2 font-mono text-[11px] tabular tracking-wider text-ink-3">
								<span class="text-mark">↳</span> {p.outcome}
							</p>
						)}

						<div class="mt-4 flex items-center justify-between gap-4">
							<ul class="flex flex-wrap gap-x-3 gap-y-1 text-[11px] font-mono tabular text-ink-3 tracking-wider">
								{p.tech.map((t, ti) => (
									<li class="inline-flex items-center gap-3">
										{ti > 0 && (
											<span aria-hidden="true" class="text-ink-5">
												/
											</span>
										)}
										{t}
									</li>
								))}
							</ul>
							{isClient ? (
								<span class="font-mono text-[10px] tabular text-clay tracking-[0.12em] uppercase">
									NDA
								</span>
							) : (
								<span
									aria-hidden="true"
									class="font-mono text-[11px] tabular text-ink-3 tracking-widest uppercase inline-flex items-center gap-1.5 transition-transform group-hover:translate-x-1 group-hover:text-mark"
								>
									source <span>↗</span>
								</span>
							)}
						</div>
					</div>
				</Tag>
			);
		})
	}
</div>
