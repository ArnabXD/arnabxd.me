---
import { data } from "~/data";

const { site, contact } = data;

const tickerItems = [
	"Available for hire",
	"React Native · Next.js",
	"Based in Kolkata, IN",
	"Open to freelance & full-time",
	"Currently @ Metafic",
	"Animation-obsessed",
];
const ticker = [...tickerItems, ...tickerItems];

const today = new Date().toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "2-digit",
});
---

<section
	aria-label="Introduction"
	class="relative pt-8 md:pt-16 pb-16 md:pb-28"
>
	<!-- top meta row -->
	<div
		class="grid grid-cols-[auto_1fr_auto] md:grid-cols-12 items-center gap-3 md:gap-6 rise"
		style="--d: 60ms"
	>
		<div
			class="md:col-span-3 eyebrow inline-flex items-center whitespace-nowrap"
		>
			<span class="relative flex h-2 w-2 mr-2">
				<span
					class="animate-ping absolute inline-flex h-full w-full rounded-full bg-mark-2 opacity-75"
				></span>
				<span class="relative inline-flex rounded-full h-2 w-2 bg-mark-2"
				></span>
			</span>
			<span class="font-mono tracking-widest text-[10.5px] text-mark-2"
				>{site.status.toUpperCase()}</span
			>
		</div>
		<div class="hairline-soft md:col-span-6" aria-hidden="true"></div>
		<div
			class="md:col-span-3 eyebrow md:text-right tabular whitespace-nowrap font-mono text-[10.5px]"
		>
			{today}
		</div>
	</div>

	<!-- name -->
	<h1
		class="mt-8 md:mt-14 leading-[0.95] tracking-[-0.045em] text-ink relative"
	>
		<!-- Dynamic atmospheric color mesh spots -->
		<div
			class="absolute -top-10 -left-10 w-48 h-48 bg-mark/10 rounded-full blur-[80px] pointer-events-none"
			aria-hidden="true"
		>
		</div>
		<div
			class="absolute top-20 right-10 w-64 h-64 bg-mark-2/5 rounded-full blur-[100px] pointer-events-none"
			aria-hidden="true"
		>
		</div>

		<span
			class="block font-display font-light text-[clamp(56px,15vw,200px)] pb-2 rise text-ink-2"
			style="--d: 140ms"
		>
			Arnab
		</span>
		<span
			class="block font-display font-semibold text-[clamp(64px,17vw,220px)] pb-4 mt-[-0.05em] rise text-ink"
			style="--d: 220ms"
		>
			Paryali<span class="text-mark animate-pulse">.</span>
		</span>
	</h1>

	<!-- spec strip below the name -->
	<div
		class="mt-6 md:mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[10.5px] tabular tracking-[0.14em] uppercase text-ink-3 rise"
		style="--d: 280ms"
	>
		<span
			><span class="text-ink-5">[</span> engineer.ts <span class="text-ink-5"
				>]</span
			></span
		>
		<span class="text-ink-5">·</span>
		<span>v.{new Date().getFullYear() - 2020}.0</span>
		<span class="text-ink-5">·</span>
		<span>kol - utc+05:30</span>
		<span class="text-ink-5">·</span>
		<span class="text-mark-2 flex items-center gap-1"
			><span class="animate-pulse">●</span> online</span
		>
	</div>

	<!-- intro grid -->
	<div
		class="mt-12 md:mt-20 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-10 rise"
		style="--d: 360ms"
	>
		<!-- left column: tagline -->
		<div class="md:col-span-7">
			<p class="eyebrow mb-4 inline-flex items-center gap-2 font-mono">
				<span class="hairline w-6 bg-mark" aria-hidden="true"></span>
				<span><span class="text-mark">§</span> 00_about_me</span>
			</p>
			<p
				class="font-display text-[22px] sm:text-[26px] md:text-[32px] leading-[1.22] text-ink tracking-tight font-normal max-w-[34ch] md:max-w-none"
			>
				I've been writing React Native and Next.js for{" "}
				<span class="font-mono italic text-[0.82em] text-mark"
					>five-plus years</span
				> and I still get a little too excited about smooth animations. TypeScript
				everywhere,{" "}
				<span
					class="underline decoration-mark decoration-2 underline-offset-[6px]"
					>cross-platform by default</span
				> - used to lead frontend at INT, now building at Metafic.
			</p>
		</div>

		<!-- right column: facts table styled as a console diagnostic block -->
		<div class="md:col-span-5 md:pl-10 md:border-l border-rule-soft relative">
			<div
				class="absolute top-0 right-0 flex gap-1.5 opacity-60"
				aria-hidden="true"
			>
				<span class="w-2.5 h-2.5 rounded-full bg-red-500/30"></span>
				<span class="w-2.5 h-2.5 rounded-full bg-yellow-500/30"></span>
				<span class="w-2.5 h-2.5 rounded-full bg-green-500/30"></span>
			</div>
			<p class="eyebrow mb-5 font-mono">
				<span class="text-mark">[sys_spec]</span> diag_01
			</p>
			<dl class="space-y-4 md:space-y-5 text-[13.5px] md:text-[14px]">
				<div class="grid grid-cols-[72px_1fr] md:grid-cols-[88px_1fr] gap-4">
					<dt class="eyebrow pt-0.5 font-mono">Role</dt>
					<dd class="text-ink font-mono">Software Engineer</dd>
				</div>
				<div class="hairline-soft"></div>
				<div class="grid grid-cols-[72px_1fr] md:grid-cols-[88px_1fr] gap-4">
					<dt class="eyebrow pt-0.5 font-mono">Stack</dt>
					<dd class="font-mono text-mark">RN · Next · TS</dd>
				</div>
				<div class="hairline-soft"></div>
				<div class="grid grid-cols-[72px_1fr] md:grid-cols-[88px_1fr] gap-4">
					<dt class="eyebrow pt-0.5 font-mono">Based</dt>
					<dd class="text-ink font-mono">
						<a
							href={contact.location.url}
							target="_blank"
							rel="noreferrer"
							class="hover:text-mark transition-colors inline-flex items-center gap-1"
						>
							{contact.location.text}, IN <span
								class="font-mono text-ink-4 tabular text-[11px]">UTC+05:30</span
							>
						</a>
					</dd>
				</div>
				<div class="hairline-soft"></div>
				<div class="grid grid-cols-[72px_1fr] md:grid-cols-[88px_1fr] gap-4">
					<dt class="eyebrow pt-0.5 font-mono">Status</dt>
					<dd class="text-mark-2 font-mono flex items-center gap-1.5">
						<span class="relative flex h-2 w-2">
							<span
								class="animate-ping absolute inline-flex h-full w-full rounded-full bg-mark-2 opacity-75"
							></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-mark-2"
							></span>
						</span>
						{site.status}
					</dd>
				</div>
			</dl>
		</div>
	</div>

	<!-- CTA -->
	<div
		class="mt-12 md:mt-16 flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-x-8 gap-y-5 rise"
		style="--d: 480ms"
	>
		<a
			href={`mailto:${contact.email}`}
			class="group inline-flex items-center gap-3 bg-paper-2 border border-rule hover:border-mark hover:shadow-[0_0_15px_rgba(20,184,166,0.25)] text-ink px-5 sm:px-6 py-3.5 transition-all duration-300 w-full sm:w-auto justify-between sm:justify-start"
		>
			<span class="font-mono text-[13px] font-medium tracking-tight text-mark"
				>init_contact()</span
			>
			<span
				class="font-mono text-[10.5px] sm:text-[11px] tabular tracking-[0.08em] sm:tracking-widest truncate max-w-45 sm:max-w-none text-ink-3 group-hover:text-ink transition-colors"
				>{contact.email}</span
			>
			<span
				aria-hidden="true"
				class="text-[16px] text-mark transition-transform group-hover:translate-x-1 shrink-0"
				>→</span
			>
		</a>
		<div
			class="flex items-center gap-4 sm:gap-5 text-[13px] text-ink-3 font-mono"
		>
			<a
				href={contact.socials.github}
				target="_blank"
				rel="noreferrer"
				class="hover:text-mark transition-colors">GitHub</a
			>
			<span class="text-ink-5">·</span>
			<a
				href={contact.socials.linkedin}
				target="_blank"
				rel="noreferrer"
				class="hover:text-mark transition-colors">LinkedIn</a
			>
			<span class="text-ink-5">·</span>
			<a
				href={contact.socials.twitter}
				target="_blank"
				rel="noreferrer"
				class="hover:text-mark transition-colors">Twitter</a
			>
			<span class="text-ink-5">·</span>
			<a
				href={contact.socials.upwork}
				target="_blank"
				rel="noreferrer"
				class="hover:text-mark transition-colors">Upwork</a
			>
		</div>
	</div>

	<!-- Ticker with developer console stream styling -->
	<div
		class="relative mt-16 md:mt-28 -mx-6 md:-mx-12 lg:-mx-16 border-y border-rule overflow-hidden bg-paper-2/20 backdrop-blur-[2px] fade fade-edges"
		style="--d: 600ms"
		aria-hidden="true"
	>
		<div class="flex marquee whitespace-nowrap py-3 md:py-4">
			{
				ticker.map((t, _i) => (
					<span class="inline-flex items-center gap-5 md:gap-6 px-5 md:px-6 font-mono text-[13px] md:text-[15px] font-medium tracking-normal text-ink-2">
						<span class="text-mark-2 opacity-80">&gt;&gt;</span>
						{t}
						<span class="text-mark not-italic font-sans text-[12px] md:text-[14px]">
							✦
						</span>
					</span>
				))
			}
		</div>
	</div>
</section>
