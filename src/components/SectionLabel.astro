---
type Props = {
  index: string;
  name: string;
  meta?: string;
  id?: string;
};

const { index, name, meta, id } = Astro.props;
---

<div id={id} class="scroll-mt-24">
  <div class="grid grid-cols-12 gap-4 items-end">
    <div class="col-span-12 md:col-span-2">
      <span
        aria-hidden="true"
        class="font-display font-semibold text-[80px] md:text-[120px] leading-[0.85] text-mark block tabular tracking-[-0.05em]"
      >
        {index}
      </span>
    </div>
    <div class="col-span-12 md:col-span-10 md:pb-3">
      <p class="eyebrow mb-2">Chapter {index}</p>
      <h2 class="font-display text-[44px] md:text-[64px] leading-[0.95] tracking-[-0.035em] text-ink font-medium">
        {name.charAt(0).toUpperCase() + name.slice(1)}
        {meta && <span class="text-ink-4 font-mono italic text-[14px] md:text-[16px] ml-3 align-middle tracking-normal"> — {meta}</span>}
      </h2>
    </div>
  </div>
  <span class="hairline block mt-6"></span>
</div>
