---
import { getCollection } from "astro:content";

import Base from "~/layouts/Base.astro";
import Hero from "~/components/Hero.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import ExperienceList from "~/components/ExperienceList.astro";
import Education from "~/components/Education.astro";
import ProjectGrid from "~/components/ProjectGrid.astro";
import SkillMatrix from "~/components/SkillMatrix.astro";
import BlogFeed from "~/components/BlogFeed.astro";
import ContactPanel from "~/components/ContactPanel.astro";
import { data } from "~/data";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const counts = {
	experience: data.experience.length,
	projects: data.projects.length,
	skills: data.skills.reduce((n, g) => n + g.skills.length, 0),
};
---

<Base image="/og/home.png">
	<Hero />

	<section class="mt-20 md:mt-32">
		<SectionLabel
			index="01"
			name="experience"
			meta={`${counts.experience} engagements`}
			id="experience"
		/>
		<ExperienceList />
	</section>

	<section class="mt-24 md:mt-36">
		<SectionLabel
			index="02"
			name="education"
			meta="formal training"
			id="education"
		/>
		<Education />
	</section>

	<section class="mt-24 md:mt-36">
		<SectionLabel
			index="03"
			name="projects"
			meta={`${counts.projects} open-source builds`}
			id="projects"
		/>
		<ProjectGrid limit={4} />
		<div class="mt-10 flex justify-end">
			<a
				href="/works"
				class="group inline-flex items-baseline gap-3 font-mono text-[12px] tabular tracking-[0.08em] uppercase text-ink hover:text-accent transition-colors"
			>
				<span
					class="hairline w-10 group-hover:bg-accent transition-colors"
					aria-hidden="true"></span>
				View all works
				<span
					aria-hidden="true"
					class="transition-transform group-hover:translate-x-1">→</span
				>
			</a>
		</div>
	</section>

	<section class="mt-24 md:mt-36">
		<SectionLabel
			index="04"
			name="skills"
			meta={`${counts.skills} entries`}
			id="skills"
		/>
		<SkillMatrix />
	</section>

	{
		posts.length > 0 && (
			<section class="mt-24 md:mt-36">
				<SectionLabel
					index="05"
					name="blog"
					meta={`${posts.length} recent`}
					id="blog"
				/>
				<BlogFeed entries={posts} compact />
				<div class="mt-10 flex justify-end">
					<a
						href="/blog"
						class="group inline-flex items-baseline gap-3 font-mono text-[12px] tabular tracking-[0.08em] uppercase text-ink hover:text-accent transition-colors"
					>
						<span
							class="hairline w-10 group-hover:bg-accent transition-colors"
							aria-hidden="true"
						/>
						View all entries
						<span
							aria-hidden="true"
							class="transition-transform group-hover:translate-x-1"
						>
							→
						</span>
					</a>
				</div>
			</section>
		)
	}

	<section class="mt-24 md:mt-36">
		<SectionLabel
			index="06"
			name="contact"
			meta="open channel"
			id="contact-label"
		/>
		<ContactPanel />
	</section>
</Base>
