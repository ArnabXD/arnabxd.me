---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

import Base from "~/layouts/Base.astro";
import ViewCounter from "~/components/ViewCounter";

export async function getStaticPaths() {
	const posts = await getCollection("blog", ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);

const fmt = (date: Date) =>
	date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});

const readTime =
	(remarkPluginFrontmatter as { minutesRead?: string })?.minutesRead ?? null;
---

<Base title={`${post.data.title} · Arnab Paryali`} description={post.data.description}>
	<article class="mx-auto mt-10 md:mt-20 max-w-[72ch]">
		<nav aria-label="breadcrumb" class="fade" style="--d: 40ms">
			<a
				href="/blog"
				class="inline-flex items-center gap-2 font-mono text-[11px] tabular tracking-[0.08em] uppercase text-ink-3 hover:text-mark transition-colors"
			>
				<span aria-hidden="true">←</span>
				Back to journal
			</a>
		</nav>

		<header class="mt-7 md:mt-8 pb-8 md:pb-10 border-b border-rule rise" style="--d: 120ms">
			<div class="flex flex-wrap items-center gap-x-3 md:gap-x-4 gap-y-2 font-mono text-[10.5px] md:text-[11px] tabular tracking-[0.06em] text-ink-3">
				<time datetime={post.data.pubDate.toISOString()}>
					{fmt(post.data.pubDate)}
				</time>
				{readTime && (
					<>
						<span class="text-ink-5">·</span>
						<span>{readTime}</span>
					</>
				)}
				<span class="text-ink-5">·</span>
				<ViewCounter client:only="react" slug={post.id} increment />
			</div>

			<h1 class="mt-5 md:mt-6 font-display text-[clamp(34px,8vw,68px)] leading-[0.98] tracking-[-0.04em] text-ink font-semibold">
				{post.data.title}
			</h1>

			<p class="mt-5 md:mt-6 font-display text-[18px] md:text-[24px] leading-[1.3] text-ink-2 max-w-[58ch] tracking-[-0.02em]">
				{post.data.description}
			</p>

			{
				post.data.tags.length > 0 && (
					<ul class="mt-7 flex flex-wrap gap-x-3 font-mono text-[11px] tabular tracking-[0.05em] text-ink-3">
						{post.data.tags.map((t, i) => (
							<li class="inline-flex items-center gap-3">
								{i > 0 && <span aria-hidden="true" class="text-ink-5">/</span>}
								{t}
							</li>
						))}
					</ul>
				)
			}
		</header>

		{
			post.data.cover && (
				<div class="mt-10 overflow-hidden border border-rule">
					<Image
						src={post.data.cover}
						alt={post.data.coverAlt ?? post.data.title}
						class="w-full"
					/>
				</div>
			)
		}

		<div class="prose-paper mt-12 rise" style="--d: 220ms">
			<Content />
		</div>

		<footer class="mt-20 pt-6 border-t border-rule flex items-center justify-between font-mono text-[11px] tabular tracking-[0.06em] text-ink-3">
			<a href="/blog" class="hover:text-mark transition-colors">
				← Back to journal
			</a>
			<span>
				End of entry · {fmt(post.data.updatedDate ?? post.data.pubDate)}
			</span>
		</footer>
	</article>
</Base>
